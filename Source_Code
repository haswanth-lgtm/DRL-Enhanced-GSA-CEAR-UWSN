# code for transmission energy consuption per round
import matplotlib.pyplot as plt

# Rounds
rounds = [0, 200, 400, 600, 800, 1000, 1200, 1400, 1600, 1800, 2000]

# Transmission Energy Consumption (Sample Values)
energy_consumption = [2, 5, 9, 14, 20, 27, 35, 44, 54, 65, 77]

plt.figure(figsize=(8,5))
