#  code for residual energy

import matplotlib.pyplot as plt

rounds = [0,200,400,600,800,1000,1200,1400,1600,1800]
energy = [100,95,90,85,79,72,65,58,50,42]

plt.plot(rounds, energy, marker='o')
plt.title("Residual Energy")
plt.xlabel("Rounds")
plt.ylabel("Residual Energy (%)")
plt.grid(True)
plt.show()

